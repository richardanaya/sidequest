  "objectives": [
    { "when": { "flag": "tookBlade" }, "text": "Goal: open the garden gate" },
    { "when": { "flag": "offeredBlossom" }, "text": "Goal: take the blade from the altar" },
    { "when": { "hasItem": "blossom" }, "text": "Goal: offer the blossom on the altar" },
    { "text": "Goal: make an offering at the altar" }
